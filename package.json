{
    "name": "classic-asp-language-support",
    "displayName": "Classic ASP Language Support",
    "description": "Complete language support for Classic ASP files with formatting, IntelliSense, snippets, and auto-completion for HTML, CSS, JavaScript, and VBScript.",
    "version": "0.3.4",
    "icon": "images/icon.png",
    "publisher": "ashtonckj",
    "repository": {
        "type": "git",
        "url": "https://github.com/ashtonckj/Classic-ASP-Language-Support.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Snippets",
        "Other"
    ],
    "keywords": [
        "ASP",
        "Classic",
        "Classic ASP",
        "Active Server Pages",
        "VBScript",
        "HTML",
        "CSS",
        "JavaScript",
        "SQL",
        "Syntax Highlighting",
        "Formatter",
        "Intellisense",
        "Autocomplete",
        "Snippets"
    ],
    "license": "MIT",
    "activationEvents": [
        "onLanguage:asp"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "asp",
                "aliases": [
                    "ASP",
                    "Classic ASP",
                    "asp"
                ],
                "extensions": [
                    ".asp",
                    ".inc"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "asp",
                "scopeName": "text.html.asp",
                "path": "./syntaxes/asp.tmLanguage.json",
                "embeddedLanguages": {
                    "text.html.basic": "html",
                    "source.css": "css",
                    "source.js": "javascript",
                    "source.vbscript.embedded.asp": "vb"
                }
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "asp",
                "scopes": {
                    "function": [
                        "entity.name.function.asp"
                    ],
                    "function.declaration": [
                        "entity.name.function.asp"
                    ],
                    "namespace": [
                        "entity.name.function.asp"
                    ],
                    "namespace.declaration": [
                        "entity.name.function.asp"
                    ],
                    "variable": [
                        "variable.other.asp"
                    ],
                    "variable.declaration": [
                        "variable.other.asp"
                    ],
                    "parameter": [
                        "variable.parameter.function.asp"
                    ],
                    "parameter.declaration": [
                        "variable.parameter.function.asp"
                    ],
                    "enumMember": [
                        "variable.other.constant.asp"
                    ],
                    "enumMember.declaration.readonly": [
                        "variable.other.constant.asp"
                    ],
                    "enumMember.readonly": [
                        "variable.other.constant.asp"
                    ],
                    "sqlDml": [
                        "keyword.other.DML.sql"
                    ],
                    "sqlDdl": [
                        "keyword.other.DDL.sql"
                    ],
                    "sqlLogical": [
                        "keyword.operator.logical.sql"
                    ],
                    "sqlKeyword": [
                        "keyword.other.sql"
                    ],
                    "sqlFunction": [
                        "support.function.aggregate.sql"
                    ],
                    "sqlType": [
                        "storage.type.sql"
                    ],
                    "sqlVariable": [
                        "variable.parameter.sql"
                    ],
                    "sqlNumber": [
                        "constant.numeric.sql"
                    ],
                    "sqlBracketPunct": [
                        "constant.numeric.sql"
                    ],
                    "sqlBracketContent": [
                        "entity.name.type.class.sql"
                    ],
                    "sqlTable": [
                        "variable.other.table.sql"
                    ],
                    "sqlColumn": [
                        "variable.other.column.sql"
                    ]
                }
            }
        ],
        "snippets": [
            {
                "language": "asp",
                "path": "./snippets/html.json"
            },
            {
                "language": "asp",
                "path": "./snippets/asp.json"
            },
            {
                "language": "asp",
                "path": "./snippets/javascript.json"
            }
        ],
        "keybindings": [
            {
                "command": "asp.insertLineBreak",
                "key": "enter",
                "when": "editorTextFocus && editorLangId == asp && !editorHasSelection && !suggestWidgetVisible && !renameInputVisible && !inSnippetMode"
            },
            {
                "command": "asp.insertTab",
                "key": "tab",
                "when": "editorTextFocus && !editorReadonly && editorLangId == asp && !suggestWidgetVisible && !editorHasSelection"
            }
        ],
        "configuration": [
            {
                "title": "ASP Formatting",
                "properties": {
                    "aspLanguageSupport.keywordCase": {
                        "type": "string",
                        "default": "PascalCase",
                        "enum": [
                            "lowercase",
                            "UPPERCASE",
                            "PascalCase"
                        ],
                        "enumDescriptions": [
                            "if, then, end if, dim",
                            "IF, THEN, END IF, DIM",
                            "If, Then, End If, Dim"
                        ],
                        "description": "ASP/VBScript keyword formatting style"
                    },
                    "aspLanguageSupport.useTabs": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use tabs instead of spaces for ASP code indentation"
                    },
                    "aspLanguageSupport.indentSize": {
                        "type": "number",
                        "default": 2,
                        "enum": [
                            2,
                            4,
                            8
                        ],
                        "description": "Number of spaces per indentation level for ASP code"
                    },
                    "aspLanguageSupport.asptagsOnSameLine": {
                        "type": "boolean",
                        "default": false,
                        "description": "Keep <% and %> on same line as code (default: separate lines)"
                    }
                }
            },
            {
                "title": "HTML, CSS & JavaScript Formatting",
                "properties": {
                    "aspLanguageSupport.prettier.printWidth": {
                        "type": "number",
                        "default": 80,
                        "description": "Maximum line length (Prettier)"
                    },
                    "aspLanguageSupport.prettier.tabWidth": {
                        "type": "number",
                        "default": 2,
                        "enum": [
                            2,
                            4,
                            8
                        ],
                        "description": "Spaces per indentation level (Prettier)"
                    },
                    "aspLanguageSupport.prettier.useTabs": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use tabs instead of spaces (Prettier)"
                    },
                    "aspLanguageSupport.prettier.bracketSameLine": {
                        "type": "boolean",
                        "default": true,
                        "description": "Put > of multi-line elements on last line (Prettier)"
                    },
                    "aspLanguageSupport.prettier.semi": {
                        "type": "boolean",
                        "default": true,
                        "description": "Add semicolons to JavaScript statements (Prettier)"
                    },
                    "aspLanguageSupport.prettier.singleQuote": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use single quotes in JavaScript (Prettier)"
                    },
                    "aspLanguageSupport.prettier.arrowParens": {
                        "type": "string",
                        "default": "always",
                        "enum": [
                            "always",
                            "avoid"
                        ],
                        "enumDescriptions": [
                            "(x) => x",
                            "x => x"
                        ],
                        "description": "Arrow function parameter parentheses (Prettier)"
                    },
                    "aspLanguageSupport.prettier.trailingComma": {
                        "type": "string",
                        "default": "es5",
                        "enum": [
                            "none",
                            "es5",
                            "all"
                        ],
                        "enumDescriptions": [
                            "No trailing commas",
                            "ES5-valid locations only",
                            "Everywhere possible"
                        ],
                        "description": "Trailing comma style (Prettier)"
                    },
                    "aspLanguageSupport.prettier.endOfLine": {
                        "type": "string",
                        "default": "lf",
                        "enum": [
                            "lf",
                            "crlf",
                            "cr",
                            "auto"
                        ],
                        "enumDescriptions": [
                            "\\n (Linux/macOS)",
                            "\\r\\n (Windows)",
                            "\\r (rare)",
                            "Keep existing"
                        ],
                        "description": "Line ending style (Prettier)"
                    },
                    "aspLanguageSupport.prettier.htmlWhitespaceSensitivity": {
                        "type": "string",
                        "default": "css",
                        "enum": [
                            "css",
                            "strict",
                            "ignore"
                        ],
                        "enumDescriptions": [
                            "Respect CSS display property",
                            "Whitespace significant",
                            "Whitespace insignificant"
                        ],
                        "description": "HTML whitespace handling (Prettier)"
                    }
                }
            },
            {
                "title": "Syntax Highlighting",
                "properties": {
                    "aspLanguageSupport.highlightAspRegions": {
                        "type": "boolean",
                        "default": true,
                        "description": "Highlight ASP code regions with background colors"
                    },
                    "aspLanguageSupport.bracketLightColor": {
                        "type": "string",
                        "default": "rgba(255, 100, 0, 0.2)",
                        "description": "ASP bracket <% %> color (light theme)"
                    },
                    "aspLanguageSupport.bracketDarkColor": {
                        "type": "string",
                        "default": "rgba(0, 100, 255, 0.2)",
                        "description": "ASP bracket <% %> color (dark theme)"
                    },
                    "aspLanguageSupport.codeBlockLightColor": {
                        "type": "string",
                        "default": "rgba(100, 100, 100, 0.1)",
                        "description": "ASP code block background (light theme)"
                    },
                    "aspLanguageSupport.codeBlockDarkColor": {
                        "type": "string",
                        "default": "rgba(220, 220, 220, 0.1)",
                        "description": "ASP code block background (dark theme)"
                    }
                }
            },
            {
                "title": "IntelliSense & Completion",
                "properties": {
                    "aspLanguageSupport.enableAspCompletion": {
                        "type": "boolean",
                        "default": true,
                        "description": "Enable ASP object and VBScript keyword auto-completion"
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "prettier": "^3.8.1",
        "vscode-css-languageservice": "^6.3.9",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "16.x",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "esbuild": "^0.27.3",
        "eslint": "^8.41.0",
        "typescript": "^5.9.3"
    }
}