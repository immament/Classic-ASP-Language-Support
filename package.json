{
    "name": "classic-asp-language-support",
    "displayName": "Classic ASP Language Support",
    "description": "Formatting, IntelliSense, Auto-Completion, and Syntax Highlighting for Classic ASP files with HTML, CSS, JavaScript, SQL, and VBScript.",
    "version": "0.5.0",
    "icon": "images/icon.png",
    "publisher": "ashtonckj",
    "repository": {
        "type": "git",
        "url": "https://github.com/ashtonckj/Classic-ASP-Language-Support.git"
    },
    "sponsor": {
        "url": "https://github.com/ashtonckj/Classic-ASP-Language-Support.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters",
        "Snippets",
        "Other"
    ],
    "keywords": [
        "ASP",
        "Classic",
        "Classic ASP",
        "Active Server Pages",
        "VBScript",
        "HTML",
        "CSS",
        "JavaScript",
        "SQL",
        "Syntax Highlighting",
        "Formatter",
        "Intellisense",
        "Autocomplete",
        "Snippets"
    ],
    "license": "MIT",
    "activationEvents": [
        "onLanguage:asp"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "asp",
                "aliases": [
                    "ASP",
                    "Classic ASP",
                    "asp"
                ],
                "extensions": [
                    ".asp",
                    ".inc"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "asp",
                "scopeName": "text.html.asp",
                "path": "./syntaxes/asp.tmLanguage.json",
                "embeddedLanguages": {
                    "text.html.basic": "html",
                    "source.css": "css",
                    "source.js": "javascript",
                    "source.vbscript.embedded.asp": "vb"
                }
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "asp",
                "scopes": {
                    "function": [
                        "entity.name.function.asp"
                    ],
                    "function.declaration": [
                        "entity.name.function.asp"
                    ],
                    "namespace": [
                        "entity.name.function.asp"
                    ],
                    "namespace.declaration": [
                        "entity.name.function.asp"
                    ],
                    "variable": [
                        "variable.other.asp"
                    ],
                    "variable.declaration": [
                        "variable.other.asp"
                    ],
                    "parameter": [
                        "variable.parameter.function.asp"
                    ],
                    "parameter.declaration": [
                        "variable.parameter.function.asp"
                    ],
                    "enumMember": [
                        "variable.other.constant.asp"
                    ],
                    "enumMember.declaration.readonly": [
                        "variable.other.constant.asp"
                    ],
                    "enumMember.readonly": [
                        "variable.other.constant.asp"
                    ],
                    "sqlDml": [
                        "keyword.other.DML.sql"
                    ],
                    "sqlDdl": [
                        "keyword.other.DDL.sql"
                    ],
                    "sqlLogical": [
                        "keyword.operator.logical.sql"
                    ],
                    "sqlKeyword": [
                        "keyword.other.sql"
                    ],
                    "sqlFunction": [
                        "support.function.aggregate.sql"
                    ],
                    "sqlType": [
                        "storage.type.sql"
                    ],
                    "sqlVariable": [
                        "variable.parameter.sql"
                    ],
                    "sqlNumber": [
                        "constant.numeric.sql"
                    ],
                    "sqlBracketPunct": [
                        "constant.numeric.sql"
                    ],
                    "sqlBracketContent": [
                        "entity.name.type.class.sql"
                    ],
                    "sqlTable": [
                        "variable.other.table.sql"
                    ],
                    "sqlColumn": [
                        "variable.other.column.sql"
                    ]
                }
            }
        ],
        "snippets": [
            {
                "language": "asp",
                "path": "./snippets/html.json"
            },
            {
                "language": "asp",
                "path": "./snippets/asp.json"
            },
            {
                "language": "asp",
                "path": "./snippets/javascript.json"
            }
        ],
        "keybindings": [
            {
                "command": "asp.insertLineBreak",
                "key": "enter",
                "when": "editorTextFocus && editorLangId == asp && !editorHasSelection && !suggestWidgetVisible && !renameInputVisible && !inSnippetMode"
            },
            {
                "command": "asp.insertTab",
                "key": "tab",
                "when": "editorTextFocus && !editorReadonly && editorLangId == asp && !suggestWidgetVisible && !editorHasSelection"
            }
        ],
        "configuration": [
            {
                "title": "VBScript Formatting",
                "properties": {
                    "aspLanguageSupport.keywordCase": {
                        "type": "string",
                        "default": "PascalCase",
                        "enum": [
                            "lowercase",
                            "UPPERCASE",
                            "PascalCase"
                        ],
                        "enumDescriptions": [
                            "if, then, end if, dim",
                            "IF, THEN, END IF, DIM",
                            "If, Then, End If, Dim"
                        ],
                        "description": "VBScript keyword casing style"
                    },
                    "aspLanguageSupport.aspTagsOnSameLine": {
                        "type": "boolean",
                        "default": false,
                        "description": "Keep <% and %> on the same line as the code they wrap"
                    },
                    "aspLanguageSupport.htmlIndentMode": {
                        "type": "string",
                        "default": "flat",
                        "enum": [
                            "flat",
                            "continuation"
                        ],
                        "enumDescriptions": [
                            "VBScript always starts at column 0 regardless of HTML nesting depth. This is the Classic ASP convention and works best for files with deeply nested HTML.",
                            "VBScript indentation continues from the HTML indent level at the point where the <% block appears. Useful if you prefer a fully unified indent style."
                        ],
                        "description": "Controls how VBScript indentation relates to the surrounding HTML structure"
                    },
                    "aspLanguageSupport.virtualRoot": {
                        "type": "string",
                        "default": "",
                        "description": "Absolute path to your IIS web application root, used to resolve #include virtual=\"...\" directives. Leave empty to use the workspace folder root (the default, which works for most projects)."
                    },
                    "aspLanguageSupport.formatPreview": {
                        "type": "boolean",
                        "default": false,
                        "description": "Debug: When enabled, Alt+Shift+F opens a diff preview showing formatting changes instead of applying them directly. Close the preview and format again with this setting off to apply."
                    }
                }
            },
            {
                "title": "HTML, CSS & JavaScript Formatting (via Prettier)",
                "properties": {
                    "aspLanguageSupport.prettier.printWidth": {
                        "type": "number",
                        "default": 80,
                        "description": "Wrap lines at this column width — Prettier printWidth"
                    },
                    "aspLanguageSupport.prettier.tabWidth": {
                        "type": "number",
                        "default": 2,
                        "enum": [
                            2,
                            4,
                            8
                        ],
                        "description": "Spaces per HTML/CSS/JS indentation level — Prettier tabWidth"
                    },
                    "aspLanguageSupport.prettier.useTabs": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use tabs instead of spaces for HTML/CSS/JS — Prettier useTabs"
                    },
                    "aspLanguageSupport.prettier.bracketSameLine": {
                        "type": "boolean",
                        "default": false,
                        "description": "Put the closing > of a multi-line HTML element on the last attribute line — Prettier bracketSameLine"
                    },
                    "aspLanguageSupport.prettier.semi": {
                        "type": "boolean",
                        "default": true,
                        "description": "Add semicolons at the end of JavaScript statements — Prettier semi"
                    },
                    "aspLanguageSupport.prettier.singleQuote": {
                        "type": "boolean",
                        "default": false,
                        "description": "Use single quotes instead of double quotes in JavaScript — Prettier singleQuote"
                    },
                    "aspLanguageSupport.prettier.arrowParens": {
                        "type": "string",
                        "default": "always",
                        "enum": [
                            "always",
                            "avoid"
                        ],
                        "enumDescriptions": [
                            "(x) => x",
                            "x => x"
                        ],
                        "description": "Parentheses around single arrow function parameters — Prettier arrowParens"
                    },
                    "aspLanguageSupport.prettier.trailingComma": {
                        "type": "string",
                        "default": "es5",
                        "enum": [
                            "none",
                            "es5",
                            "all"
                        ],
                        "enumDescriptions": [
                            "No trailing commas",
                            "Trailing commas where valid in ES5 (objects, arrays)",
                            "Trailing commas wherever possible"
                        ],
                        "description": "Trailing comma style — Prettier trailingComma"
                    },
                    "aspLanguageSupport.prettier.endOfLine": {
                        "type": "string",
                        "default": "lf",
                        "enum": [
                            "lf",
                            "crlf",
                            "cr",
                            "auto"
                        ],
                        "enumDescriptions": [
                            "\\n only (Linux / macOS)",
                            "\\r\\n (Windows)",
                            "\\r only (rare)",
                            "Preserve existing line endings"
                        ],
                        "description": "Line ending style — Prettier endOfLine"
                    },
                    "aspLanguageSupport.prettier.htmlWhitespaceSensitivity": {
                        "type": "string",
                        "default": "css",
                        "enum": [
                            "css",
                            "strict",
                            "ignore"
                        ],
                        "enumDescriptions": [
                            "Follow the CSS display property for whitespace decisions",
                            "All whitespace is significant",
                            "All whitespace is insignificant"
                        ],
                        "description": "HTML whitespace sensitivity — Prettier htmlWhitespaceSensitivity"
                    }
                }
            },
            {
                "title": "Syntax Highlighting",
                "properties": {
                    "aspLanguageSupport.highlightAspRegions": {
                        "type": "boolean",
                        "default": true,
                        "description": "Highlight ASP code regions with background colors"
                    },
                    "aspLanguageSupport.bracketLightColor": {
                        "type": "string",
                        "default": "rgba(255, 100, 0, 0.2)",
                        "description": "ASP bracket <% %> color (light theme)"
                    },
                    "aspLanguageSupport.bracketDarkColor": {
                        "type": "string",
                        "default": "rgba(0, 100, 255, 0.2)",
                        "description": "ASP bracket <% %> color (dark theme)"
                    },
                    "aspLanguageSupport.codeBlockLightColor": {
                        "type": "string",
                        "default": "rgba(100, 100, 100, 0.1)",
                        "description": "ASP code block background (light theme)"
                    },
                    "aspLanguageSupport.codeBlockDarkColor": {
                        "type": "string",
                        "default": "rgba(220, 220, 220, 0.1)",
                        "description": "ASP code block background (dark theme)"
                    }
                }
            }
        ],
        "configurationDefaults": {
            "[asp]": {
                "editor.wordBasedSuggestions": "off"
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vscode-css-languageservice": "^6.3.9",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^16.18.126",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "esbuild": "^0.27.3",
        "eslint": "^8.41.0",
        "typescript": "^5.9.3"
    }
}
