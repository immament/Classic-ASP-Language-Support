{
    "ASP Code Block": {
        "prefix": "asp",
        "body": [
            "<%",
            "\t$0",
            "%>"
        ],
        "description": "ASP code block"
    },
    "ASP Output": {
        "prefix": "aspo",
        "body": "<%= $0 %>",
        "description": "ASP output expression"
    },
    "Response.Write": {
        "prefix": "rw",
        "body": "Response.Write(\"$0\")",
        "description": "Write output to page"
    },
    "Response.Redirect": {
        "prefix": "rr",
        "body": "Response.Redirect(\"$0\")",
        "description": "Redirect to another page"
    },
    "Request.Form": {
        "prefix": "rf",
        "body": "Request.Form(\"$0\")",
        "description": "Get form data"
    },
    "Request.QueryString": {
        "prefix": "rq",
        "body": "Request.QueryString(\"$0\")",
        "description": "Get query string parameter"
    },
    "Server.MapPath": {
        "prefix": "smp",
        "body": "Server.MapPath(\"$0\")",
        "description": "Map virtual path to physical path"
    },
    "Server.CreateObject": {
        "prefix": "sco",
        "body": "Server.CreateObject(\"$0\")",
        "description": "Create COM object"
    },
    "Database Connection": {
        "prefix": "dbconn",
        "body": [
            "Dim ${1:conn}",
            "Set ${1:conn} = Server.CreateObject(\"ADODB.Connection\")",
            "${1:conn}.Open \"${2:connectionString}\"",
            "$0",
            "${1:conn}.Close",
            "Set ${1:conn} = Nothing"
        ],
        "description": "Database connection template — type your connection variable name once and it updates everywhere"
    },
    "Recordset": {
        "prefix": "rs",
        "body": [
            "Dim ${1:rs}",
            "Set ${1:rs} = Server.CreateObject(\"ADODB.Recordset\")",
            "${1:rs}.Open \"${2:SQL}\", ${3:conn}",
            "Do While Not ${1:rs}.EOF",
            "\t$0",
            "\t${1:rs}.MoveNext",
            "Loop",
            "${1:rs}.Close",
            "Set ${1:rs} = Nothing"
        ],
        "description": "ADO Recordset template — type your recordset variable name once and it updates everywhere"
    },
    "Option Explicit": {
        "prefix": "opt",
        "body": "Option Explicit",
        "description": "Require variable declaration"
    },
    "Include File": {
        "prefix": "inc",
        "body": "<!--#include file=\"${0:filename.asp}\"-->",
        "description": "Include another ASP file"
    }
}